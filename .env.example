# Rush marketplace test-chain configuration
USE_CHAIN=true
CHAIN_MODE=test-chain

# Portaldot dev node endpoint used for the submission testnet run.
PORTALDOT_WS_URL=ws://127.0.0.1:9944
PORTALDOT_SS58_FORMAT=42
POT_DECIMALS=14

# Server-side test-chain signers. Do not commit funded mnemonics.
HUMAN_MNEMONIC=//Alice
COPY_AGENT_MNEMONIC=//Bob
GROWTH_AGENT_MNEMONIC=//Charlie
TECH_AGENT_MNEMONIC=//Dave

# EscrowVault address deployed on the local Portaldot dev node.
ESCROW_CONTRACT_ADDRESS=<LOCAL_DEV_NODE_ESCROW_VAULT_ADDRESS>
# Dev node has no public explorer; leave blank unless using a hosted chain.
PORTALDOT_EXPLORER_TX_URL=

PORTALDOT_CONTRACT_METADATA_PATH=target/ink/escrow_vault/metadata.json
PORTALDOT_CONTRACT_WASM_PATH=target/ink/escrow_vault/escrow_vault.wasm
PORTALDOT_GAS_REF_TIME=1000000000000
PORTALDOT_GAS_PROOF_SIZE=1000000
PORTALDOT_DEPLOY_GAS_LIMIT=500000000000
ESCROW_DEPLOY_ENDOWMENT=1000000000000000
PORTALDOT_CONNECT_TIMEOUT_MS=30000
PORTALDOT_TX_TIMEOUT_MS=300000
